<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_bg_self">

    <!-- Top Row: Lock icon + Type badge on left, Timer on right -->
    <LinearLayout
        android:id="@+id/top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Lock type icon -->
        <ImageView
            android:id="@+id/icon_lock_type"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_lock"
            android:background="@drawable/icon_glass_bg"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/lock_icon_desc" />

        <!-- Lock type badge -->
        <TextView
            android:id="@+id/text_lock_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="自锁"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

        <!-- Spacer (must use TextView, plain View not supported in RemoteViews) -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Timer badge -->
        <LinearLayout
            android:id="@+id/timer_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/timer_badge_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/icon_timer"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_timer"
                android:contentDescription="@string/timer_icon_desc" />

            <Chronometer
                android:id="@+id/text_remaining_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom section -->
    <LinearLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <!-- Tags row (frozen, hygiene, keyholder) -->
        <LinearLayout
            android:id="@+id/tags_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tag_frozen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计时暂停"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/tag_frozen_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tag_hygiene"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="临时解锁"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/tag_hygiene_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tag_keyholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="有管理员"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/tag_keyholder_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Status row: dot + status text, likes on right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Status dot (must use ImageView, plain View not supported in RemoteViews) -->
            <ImageView
                android:id="@+id/status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/status_dot_active"
                android:contentDescription="" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="锁定中"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Likes badge -->
            <LinearLayout
                android:id="@+id/likes_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/likes_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_heart"
                    android:contentDescription="@string/likes_desc" />

                <TextView
                    android:id="@+id/text_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state overlay -->
    <TextView
        android:id="@+id/text_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/widget_no_active_lock"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone" />
</RelativeLayout>
