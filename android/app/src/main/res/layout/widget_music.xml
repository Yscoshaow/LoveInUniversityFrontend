<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/music_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_bg_music">

    <!-- Left: Cover Art -->
    <ImageView
        android:id="@+id/music_cover_art"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:background="@drawable/music_cover_bg"
        android:clipToOutline="true"
        android:contentDescription="" />

    <!-- Center: Track Info + Progress + Controls -->
    <LinearLayout
        android:id="@+id/music_info_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/music_cover_art"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <!-- Track Title -->
        <TextView
            android:id="@+id/music_track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever" />

        <!-- Work/Artist Title -->
        <TextView
            android:id="@+id/music_work_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Subtitle Text -->
        <TextView
            android:id="@+id/music_subtitle_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCB388FF"
            android:textSize="10sp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/music_progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/music_progress_drawable" />

        <!-- Time labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/music_time_current"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#66FFFFFF"
                android:textSize="10sp"
                android:text="0:00" />

            <TextView
                android:id="@+id/music_time_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="10sp"
                android:text="0:00"
                android:gravity="end" />
        </LinearLayout>

        <!-- Control Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/music_btn_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_music_prev"
                android:background="@drawable/music_btn_bg"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/music_widget_prev" />

            <ImageButton
                android:id="@+id/music_btn_play_pause"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_music_play"
                android:background="@drawable/music_btn_play_bg"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@string/music_widget_play_pause" />

            <ImageButton
                android:id="@+id/music_btn_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_music_next"
                android:background="@drawable/music_btn_bg"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/music_widget_next" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state overlay -->
    <LinearLayout
        android:id="@+id/music_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_music_play"
            android:layout_marginBottom="8dp"
            android:alpha="0.5"
            android:contentDescription="" />

        <TextView
            android:id="@+id/music_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/music_widget_not_playing"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</RelativeLayout>
