<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/task_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/schedule_item_bg"
    android:paddingStart="0dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:layout_marginBottom="4dp">

    <!-- Left color indicator bar -->
    <ImageView
        android:id="@+id/task_indicator"
        android:layout_width="4dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/indicator_blue"
        android:scaleType="fitXY"
        android:contentDescription="" />

    <!-- Middle: task info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_task_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1E293B"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/text_task_course"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/text_task_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Progress bar (FrameLayout simulated) -->
        <FrameLayout
            android:id="@+id/progress_container"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/progress_bar_bg">

            <FrameLayout
                android:id="@+id/progress_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/progress_bar_fill" />
        </FrameLayout>
    </LinearLayout>

    <!-- Right: action button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btn_task_action"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/btn_action_start"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:contentDescription="" />

        <!-- Completed badge (shown instead of button when done) -->
        <TextView
            android:id="@+id/text_task_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_done"
            android:textColor="#10B981"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
