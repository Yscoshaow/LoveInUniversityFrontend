<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/managed_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_bg_shared">

    <!-- Top Row: Avatar + Wearer name + Permission badge -->
    <LinearLayout
        android:id="@+id/managed_top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Avatar placeholder -->
        <ImageView
            android:id="@+id/managed_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_users"
            android:background="@drawable/icon_glass_bg"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="" />

        <!-- Wearer name + lock type -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/managed_wearer_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/managed_lock_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFCC"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Permission badge -->
        <TextView
            android:id="@+id/managed_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />
    </LinearLayout>

    <!-- Bottom section -->
    <LinearLayout
        android:id="@+id/managed_bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Tags (frozen / hygiene) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Status dot -->
            <ImageView
                android:id="@+id/managed_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/status_dot_active"
                android:layout_gravity="center_vertical"
                android:contentDescription="" />

            <TextView
                android:id="@+id/managed_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/managed_tag_frozen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="冻结"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:background="@drawable/tag_frozen_bg"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginStart="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/managed_tag_hygiene"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="卫生开启"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:background="@drawable/tag_hygiene_bg"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginStart="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Timer badge -->
        <LinearLayout
            android:id="@+id/managed_timer_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/timer_badge_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_timer"
                android:contentDescription="" />

            <Chronometer
                android:id="@+id/managed_remaining_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/managed_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone" />
</RelativeLayout>
